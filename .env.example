# ──────────────────────────────────────────────
# Job Listings MCP Server — Environment Config
# ──────────────────────────────────────────────

# Scrape interval in hours (default: 1)
SCRAPE_INTERVAL_HOURS=1

# Max results per query (default: 25)
RESULTS_PER_QUERY=25

# Only scrape jobs posted in last N hours (default: 24)
HOURS_OLD=24

# Country for Indeed searches (default: USA)
COUNTRY=USA

# Remote-only jobs? (default: false)
IS_REMOTE=false

# Comma-separated scrape sites: linkedin,indeed,glassdoor,zip_recruiter
SCRAPE_SITES=linkedin,indeed

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yashvardhan.dev,https://yashvardhan.is-a.dev

# Server config
HOST=0.0.0.0
PORT=8000

# Data directory for SQLite DB (default: current directory)
DATA_DIR=.
